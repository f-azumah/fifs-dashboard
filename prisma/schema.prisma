generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum HabitCategory {
  HEALTH_FITNESS
  MIND_SPIRITUAL
  WORK
  PERSONAL
  HAIR_CARE
  ENGINEERING_GROWTH
}

enum HabitFrequency {
  DAILY
  WEEKLY_TARGET
  INTERVAL
}

enum TaskStatus {
  TODO
  DONE
}

enum FailureMode {
  INERTIA
  MIND_BODY_GAP
  TECHNICAL_WALL
  PLANNING_FATIGUE
}

enum ReadingStatus {
  READING
  PAUSED
  COMPLETED
}

enum GoalCategory {
  FINANCE
  HEALTH
  BUSINESS
  PERSONAL
  ENGINEERING_CREDIBILITY
}

enum OssPrStatus {
  NOT_STARTED
  RESEARCHING_ISSUE
  IN_PROGRESS
  SUBMITTED
  MERGED
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Int        @default(2) // 1 = high, 2 = medium, 3 = low
  weekOf      DateTime // Monday of the week this task belongs to
  position    Int        @default(0)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([weekOf])
}

model Habit {
  id           String         @id @default(cuid())
  name         String
  category     HabitCategory
  frequency    HabitFrequency
  weeklyTarget Int? // used when frequency = WEEKLY_TARGET (e.g. 5 out of 7 days)
  intervalDays Int? // used when frequency = INTERVAL (e.g. 49 days = every 7 weeks)
  icon         String?
  color        String?
  active       Boolean        @default(true)
  position     Int            @default(0)
  createdAt    DateTime       @default(now())
  logs         HabitLog[]
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date        DateTime // day the habit was completed (normalized to midnight UTC)
  completedAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([habitId])
}

model WeeklyReflection {
  id          String       @id @default(cuid())
  weekOf      DateTime     @unique // Monday of the week
  focus       String? // weekly goal / intention
  hoursSpent  Float? // hours spent on career goals this week
  shipped     String? // what shipped this week
  notShipped  String? // what didn't ship this week
  didShip     Boolean      @default(false) // did *something* ship, regardless of how much work got done
  failureMode FailureMode? // only meaningful when didShip = false
  updatedAt   DateTime     @updatedAt
}

model WeeklyGoal {
  id        String   @id @default(cuid())
  weekOf    DateTime // Monday of the week this goal belongs to
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([weekOf])
}

model GymSession {
  id        String   @id @default(cuid())
  date      DateTime @unique // day of the gym session (normalized to midnight UTC)
  createdAt DateTime @default(now())
}

model GymSettings {
  id           String @id @default("singleton")
  weeklyTarget Int    @default(5)
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  date      DateTime @unique // the evening this check-in was written, planning the next day
  note      String?
  updatedAt DateTime @updatedAt
}

model CurrentlyReading {
  id        String        @id @default("singleton")
  title     String?
  author    String?
  coverUrl  String?
  status    ReadingStatus @default(READING)
  updatedAt DateTime      @updatedAt
}

model QuarterlyGoal {
  id        String       @id @default(cuid())
  quarterOf DateTime // first day of the quarter
  category  GoalCategory
  title     String
  done      Boolean      @default(false)
  position  Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([quarterOf])
}

model QuarterlyWin {
  id        String   @id @default(cuid())
  quarterOf DateTime
  text      String
  createdAt DateTime @default(now())

  @@index([quarterOf])
}

model Idea {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
}

model BookLog {
  id          String   @id @default(cuid())
  title       String
  author      String?
  coverUrl    String?
  completedAt DateTime // day the book was marked completed
  createdAt   DateTime @default(now())

  @@index([completedAt])
}

model DepthLog {
  id             String      @id @default(cuid())
  weekOf         DateTime    @unique // Monday of the week
  wentDeeper     String? // what I went deeper on this week (revisiting/understanding existing code)
  explainableNow String? // specific thing I could now explain that I couldn't before
  ossPrStatus    OssPrStatus @default(NOT_STARTED)
  updatedAt      DateTime    @updatedAt
}

enum DsaConfidence {
  SHAKY
  GETTING_THERE
  SOLID
}

model DsaLogEntry {
  id             String         @id @default(cuid())
  patternFocus   String // e.g. "sliding window", "graph BFS"
  problemsSolved Int?
  stuckOn        String? // where I got stuck
  confidence     DsaConfidence?
  createdAt      DateTime       @default(now()) // not week-scoped — entries accumulate indefinitely

  @@index([createdAt])
}
